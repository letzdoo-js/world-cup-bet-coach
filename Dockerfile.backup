FROM alpine:latest

RUN apk add --no-cache git gnupg openssh-client tar coreutils

# Bake deploy key into image
COPY backup-deploy-key /root/.ssh/id_ed25519
RUN chmod 600 /root/.ssh/id_ed25519 \
    && ssh-keyscan github.com >> /root/.ssh/known_hosts 2>/dev/null \
    && git config --global user.email "backup@world-cup-bet-coach" \
    && git config --global user.name "World Cup Bet Coach Backup" \
    && git config --global init.defaultBranch main
